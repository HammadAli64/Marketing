{
  "name": "helix-prime-web",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs');for(const p of ['.next','node_modules/.cache']){try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}}\"",
    "dev": "node scripts/next-dev-webpack.cjs -H 127.0.0.1 -p 3000",
    "dev:turbo": "next dev --turbopack -H 127.0.0.1 -p 3000",
    "dev:lan": "node scripts/next-dev-webpack.cjs -H 0.0.0.0 -p 3000",
    "dev:quick": "node scripts/next-dev-webpack.cjs -H 127.0.0.1 -p 3000",
    "dev:fresh": "npm run clean && node scripts/next-dev-webpack.cjs -H 127.0.0.1 -p 3000",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start -H 0.0.0.0",
    "preview": "npm run build:clean && next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0"
  }
}
