DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gmail SMTP — use an App Password (2FA): https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=yourcompany@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=yourcompany@gmail.com
CONTACT_RECIPIENT_EMAIL=yourcompany@gmail.com

# Uploaded images are stored under backend/media/ (dev: served automatically when DEBUG=true).
# In production, configure your web server or object storage to serve MEDIA_URL.
